# ============================================================
# PolyBot - Git Ignore Rules
# ============================================================

# ── Secrets & Credentials ─────────────────────────────────
.env
*.key
*.pem
*.secret

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE & Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Runtime Data (don't commit bot state) ──────────────────
config/
*.log
*.pid
cloudflared.exe
cloudflared.log
cloudflared.out

# ── AI/Assistant Tools ────────────────────────────────────
.qwen/
.agents/
