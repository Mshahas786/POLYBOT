# ============================================================
# PolyBot v6.0 - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================
#
# Where to get these values:
#   1. Go to https://polymarket.com/portfolio/api
#   2. Create a new API key
#   3. Copy the values into the corresponding fields below
#
# WARNING: Never commit your .env file to version control.
# ============================================================

# ── REQUIRED: Polymarket Wallet ─────────────────────────────
# Your wallet's private key (must include 0x prefix)
POLY_PRIVATE_KEY=0x...

# Your wallet address on Polygon
POLY_WALLET_ADDRESS=0x...

# Relayer API key (created on Polymarket API page)
RELAYER_API_KEY_ADDRESS=0x...

# ── REQUIRED: Polymarket API Credentials ────────────────────
# These are obtained from https://polymarket.com/portfolio/api
POLY_API_KEY=your-api-key-here

# If you leave API_SECRET and PASSPHRASE blank, the bot will
# auto-generate them using your private key on first run.
# Fill them in if you want to use pre-generated values.
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── REQUIRED: RPC Settings ──────────────────────────────────
# Polygon RPC endpoint. Public RPCs work but are rate-limited.
# For production, consider a private RPC from Alchemy, Infura, etc.
POLYGON_RPC=https://polygon.drpc.org

# ── REQUIRED: Signature Type ────────────────────────────────
#  1 = EOA (Externally Owned Account) — legacy wallets
#  3 = POLY_1271 — newer Polymarket smart wallets
# If unsure, try 1 first. The bot will log if it fails.
POLY_SIGNATURE_TYPE=1

# ── OPTIONAL: Deposit Wallet (for POLY_1271 sig type) ──────
# Leave blank to use POLY_WALLET_ADDRESS as the deposit address.
# Only needed if your deposit wallet differs from your main wallet.
# POLY_DEPOSIT_WALLET_ADDRESS=0x...

# ── OPTIONAL: WebSocket Overrides ───────────────────────────
# Leave blank to use default Polymarket RTDS endpoint.
# Only needed if you run a custom RTDS relay.
# POLY_RTDS_WS_URL=wss://rtds.polymarket.com/ws

# ── OPTIONAL: Dashboard API Authentication ──────────────────
# If set, all API requests must include this key in the
# X-API-Key header. Leave blank for no authentication.
# POLYBOT_API_KEY=your-secret-api-key

# ── OPTIONAL: Logging ───────────────────────────────────────
# Values: DEBUG, INFO, WARN, ERROR (default: INFO)
POLYBOT_LOG_LEVEL=INFO

# ── OPTIONAL: Flask Server ──────────────────────────────────
# Address and port the bot's web server listens on.
# FLASK_HOST=0.0.0.0
# FLASK_PORT=3000
