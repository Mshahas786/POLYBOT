# ============================================================
# PolyBot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!
# ============================================================

# ── Wallet Configuration ──────────────────────────────────
# Your Polymarket wallet private key (NEVER share this!)
POLY_PRIVATE_KEY=your_private_key_here

# Your wallet public address (found on Polymarket profile)
POLY_WALLET_ADDRESS=your_wallet_address_here

# Signature type: 0=EOA, 1=POLY_PROXY (email), 2=GNOSIS_SAFE
# Default: 1 (most users have email/proxy wallets)
POLY_SIGNATURE_TYPE=1

# ── CLOB API Credentials ──────────────────────────────────
# Optional - will be auto-derived from private key if not provided
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Builder API Credentials (for Auto-Redeem) ─────────────
# Required for automatic claim/redeem functionality
# Get these from: Polymarket → Settings → API Keys
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# ── Network Configuration ─────────────────────────────────
# Polygon RPC endpoint (default uses reliable public nodes)
POLYGON_RPC=https://polygon-rpc.com
