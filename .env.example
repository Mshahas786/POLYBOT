# ============================================================
# PolyBot Environment Configuration
# ============================================================
# NEVER COMMIT THIS FILE. It contains your private key.
# Copy this file to .env and fill in your credentials.
# ============================================================

# --- Wallet (Required) ---
POLY_PRIVATE_KEY=your_private_key_here_without_0x_prefix
POLY_WALLET_ADDRESS=your_wallet_address_here

# --- API Credentials (Optional - generated by activate_bot.py) ---
# If left blank, the bot will auto-derive them on first run.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- Network ---
POLY_SIGNATURE_TYPE=1

# --- Flask Binding (VPS only) ---
FLASK_HOST=0.0.0.0

# --- Bot Security & Logging (Optional) ---
# Set an API key to protect sensitive endpoints (/start, /stop, /config, etc.)
# If unset, all endpoints remain open (default for local development)
POLYBOT_API_KEY=

# Log verbosity: DEBUG | INFO | WARN | ERROR (default: INFO)
POLYBOT_LOG_LEVEL=INFO
