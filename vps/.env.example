# Polymarket Bot Configuration
# Copy this file to .env and fill in your credentials

# Required for trading
POLY_PRIVATE_KEY=your_private_key_here
POLY_WALLET_ADDRESS=your_wallet_address_here

# Optional: CLOB API Credentials (will be derived if not provided)
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Required for auto-redeem (Builder API credentials)
# Get these from Polymarket Developer Dashboard
POLY_BUILDER_API_KEY=your_builder_api_key_here
POLY_BUILDER_SECRET=your_builder_secret_here
POLY_BUILDER_PASSPHRASE=your_builder_passphrase_here

# Optional: Signature Type (0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE)
# Default: 1 (POLY_PROXY for email accounts)
POLY_SIGNATURE_TYPE=1

# Optional: Custom Polygon RPC (default: https://polygon-rpc.com)
# Fallback RPCs are automatically used if the primary fails
POLYGON_RPC=https://polygon-rpc.com
